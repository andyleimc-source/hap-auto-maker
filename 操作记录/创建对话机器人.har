          "content": {
            "size": 1075,
            "mimeType": "application/json",
            "text": "{\"data\":{\"data\":[{\"summary\":\"维修工单助理\",\"description\":\"查询和管理维修工单信息，支持维修团队和服务顾问高效跟踪维修进度；避免输出客户隐私和虚假数据。\",\"icon\":\"sys_todo_office\"},{\"summary\":\"配件库存助手\",\"description\":\"实时查询和更新配件库存数据，为仓库管理人员提供库存维护支持；不涉及预测和敏感客户信息。\",\"icon\":\"sys_table\"},{\"summary\":\"客户信息助理\",\"description\":\"汇总客户资料和车辆档案，帮助销售和服务团队快速获取客户信息；禁止泄露个人隐私和编造数据。\",\"icon\":\"sys_folder-info_office\"},{\"summary\":\"保养记录助手\",\"description\":\"统计和查询车辆保养历史，支持维修技师和客户服务部门维护车辆保养档案；不进行数据预测或隐私处理。\",\"icon\":\"sys_2_3_statistics\"},{\"summary\":\"结算管理助理\",\"description\":\"管理结算单数据，辅助财务人员核对和汇总收费信息；避免生成错误账单或涉及敏感客户信息。\",\"icon\":\"sys_1_6_document\"}]},\"state\":1}"
          },
